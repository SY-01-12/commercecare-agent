# ===== CommerceCare Agent 环境变量 =====
# 复制此文件为 .env 并填入实际值

# OpenAI API Key（必填）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 服务端口（可选，默认值如下）
BACKEND_PORT=8000
FRONTEND_PORT=3000

# 日志级别（可选）
LOG_LEVEL=INFO

# 数据库路径（可选，SQLite 默认路径）
DATABASE_PATH=./data/commercecare.db

# 向量数据库路径（可选）
VECTOR_STORE_PATH=./vector_store

# 人工客服 Webhook（可选，用于转接通知）
HUMAN_AGENT_WEBHOOK_URL=
