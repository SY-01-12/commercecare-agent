# ===== CommerceCare Agent 环境变量 =====
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# OpenAI API Key（必填）
# 获取方式：https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 禁用 OpenAI Tracing（可选，设为 1 禁用遥测）
OPENAI_TRACING_DISABLED=1

# 后端服务端口（可选，默认 8000）
BACKEND_PORT=8000

# 前端服务端口（可选，默认 3000）
FRONTEND_PORT=3000

# 日志级别（可选）
LOG_LEVEL=INFO
