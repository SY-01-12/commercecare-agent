# ===== CommerceCare Agent 环境变量 =====
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# API 配置（必填）
# 如使用 OpenAI 官方：只填 OPENAI_API_KEY 即可
# 如使用第三方代理（如 CloseAI-Asia），需同时配置 OPENAI_BASE_URL
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai-proxy.org/v1

# 禁用 OpenAI Tracing（可选，设为 1 禁用遥测）
OPENAI_TRACING_DISABLED=1

# 后端服务端口（可选，默认 8000）
BACKEND_PORT=8000

# 前端服务端口（可选，默认 3000）
FRONTEND_PORT=3000

# 日志级别（可选）
LOG_LEVEL=INFO
